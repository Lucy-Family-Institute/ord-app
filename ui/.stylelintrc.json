{
  "extends": ["stylelint-config-standard"],
  "plugins": ["stylelint-scss"],
  "rules": {
    "import-notation": ["string"],
    "custom-property-pattern": null,
    "selector-class-pattern": [
      "^[a-z][a-zA-Z0-9]+$",
      {
        "message": "Expected class selector '%s' to be camel case"
      }
    ]
  }
}
