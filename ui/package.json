{
  "name": "ord-app-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "analyze": "vite-bundle-visualizer --open",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prettier": "prettier --write .",
    "lint": "eslint src *.ts *.cjs *.mjs",
    "lint:css": "stylelint '**/*.[s]css'",
    "lint:check": "prettier --check . && npm run lint && npm run lint:css",
    "preview": "vite preview",
    "prepare": "cd .. && husky ./ui/.husky",
    "add-license": "license-check-and-add add",
    "test": "vitest"
  },
  "lint-staged": {
    "(*.ts|*.tsx|*.cjs|*.mjs)": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.[s]css": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*": [
      "license-check-and-add add"
    ]
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.3.0",
    "@fastify/deepmerge": "^2.0.2",
    "@mantine/core": "^7.15.3",
    "@mantine/dates": "^7.15.3",
    "@mantine/form": "^7.15.3",
    "@mantine/hooks": "^7.15.3",
    "@mantine/notifications": "^7.15.3",
    "@reduxjs/toolkit": "^2.5.0",
    "@tabler/icons-react": "^3.22.0",
    "axios": "^1.8.2",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "html-to-image": "^1.11.13",
    "ketcher-react": "^2.27.0",
    "ketcher-standalone": "^2.27.0",
    "mantine-react-table": "^2.0.0-beta.8",
    "mime": "^4.0.6",
    "ord-schema-protobufjs": "^0.3.96",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-lazy-with-preload": "^2.2.1",
    "react-redux": "^9.2.0",
    "uuid": "^11.0.5",
    "wouter": "^3.3.5",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "license-check-and-add": "^4.0.5",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.49",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.4.0",
    "sass": "^1.81.0",
    "stylelint": "^16.11.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-scss": "^6.10.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^6.2.0",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-svgr": "^4.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.7"
  },
  "overrides": {
    "ketcher-react": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    }
  }
}
