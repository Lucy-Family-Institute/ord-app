{
  "ignore": [
    ".idea",
    ".husky",
    "README.md",
    ".gitignore",
    ".stylelintignore",
    ".prettierignore",
    "**/*.svg",
    "FILE_LICENSE"
  ],
  "license": "FILE_LICENSE",
  "licenseFormats": {
    "js|ts|tsx|scss|cjs|mjs": {
      "prepend": "/*",
      "append": " */",
      "eachLine": {
        "prepend": " * "
      }
    }
  },
  "trailingWhitespace": "TRIM"
}
